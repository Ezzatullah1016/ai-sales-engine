# Keep real prospect data OUT of version control (privacy + compliance).
# The folders are kept via .gitkeep; their contents are ignored.
data/leads_raw/*
data/leads_scored/*
output/research/*
output/outreach/*
output/proposals/*
output/meetings/*

# ...but keep the folder placeholders and the sample file
!**/.gitkeep
!data/leads_raw/sample_leads.csv

# OS / editor noise
.DS_Store
Thumbs.db
node_modules/
branch_structure.json
temp_auto_push.bat
temp_interactive_push.bat
.gitignore
